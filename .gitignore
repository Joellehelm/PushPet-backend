# See https://help.github.com/articles/ignoring-files for more about ignoring files.
/.bundle
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
!/tmp/pids
/tmp/pids/*
!/tmp/pids/.keep

/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage
!/tmp/storage/.keep

/config/master.key
.env*
!.env.example

/public/assets
/public/packs
/node_modules
